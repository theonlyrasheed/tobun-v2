# ── Sanity CMS ────────────────────────────────────────────
# Copy this to .env.local and fill in your values.
# Get the Project ID from https://sanity.io/manage → your project.

VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production
VITE_SANITY_TOKEN=
SANITY_TOKEN=

# ── Resend Email Configuration ──────────────────────────────
# Obtain an API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# The recipient email address where contact form submissions will be sent.
# Defaults to hello@tobunlateefat.com if left blank.
CONTACT_RECEIVER_EMAIL=hello@tobunlateefat.com

