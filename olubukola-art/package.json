{
  "name": "olubukola-art",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "pnpx srvx --prod -s ../client dist/server/server.js",
    "type-check": "tsc --noEmit",
    "sanity:schema": "cd sanity && npx sanity schema extract --enforce-required-fields",
    "sanity:types": "cd sanity && npx sanity typegen generate",
    "sanity:codegen": "pnpm run sanity:schema && pnpm run sanity:types",
    "sanity:dev": "cd sanity && npx sanity dev",
    "sanity:start": "cd sanity && npx sanity start",
    "sanity:build": "cd sanity && npx sanity build",
    "sanity:deploy": "cd sanity && npx sanity deploy",
    "sanity:deploy-graphql": "cd sanity && npx sanity graphql deploy"
  },
  "dependencies": {
    "@mantine/carousel": "^8.3.10",
    "@mantine/core": "^8.3.10",
    "@mantine/dates": "^8.3.10",
    "@mantine/form": "^8.3.10",
    "@mantine/hooks": "^8.3.10",
    "@mantine/notifications": "^8.3.10",
    "@sanity/client": "^6.15.9",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.2",
    "@sanity/vision": "^5.0.0",
    "@tabler/icons-react": "^3.36.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-query-devtools": "^5.90.0",
    "@tanstack/react-router": "^1.141.4",
    "@tanstack/react-router-devtools": "^1.141.4",
    "@tanstack/react-router-ssr-query": "^1.141.4",
    "@tanstack/react-start": "^1.141.5",
    "add": "^2.0.6",
    "aos": "^2.3.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.26",
    "nitro": "3.0.1-alpha.1",
    "node-mailjet": "^6.0.11",
    "photoswipe": "^5.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redaxios": "^0.5.1",
    "resend": "^6.6.0",
    "sanity": "^5.0.0",
    "styled-components": "^6.1.18",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.2",
    "@tailwindcss/postcss": "^4.1.15",
